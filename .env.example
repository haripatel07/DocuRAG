# ─────────────────────────────────────────────────────────────────────────────
# DocuRAG Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                  # Required if using OpenAI LLM or embeddings
LLM_MODEL=gpt-4o-mini                 # LLM model name
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# ── Embeddings ────────────────────────────────────────────────────────────────
# Options: "openai" | "huggingface"  (default: huggingface — no API key needed)
EMBEDDING_PROVIDER=huggingface
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RERANK_TOP_N=3
RERANKER_MODEL=ms-marco-MiniLM-L-12-v2

# ── Paths ─────────────────────────────────────────────────────────────────────
DATA_DIR=data/raw
VECTORSTORE_DIR=vectorstore
LOG_DIR=logs

# ── LangSmith Observability (optional) ────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=DocuRAG

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
CORS_ORIGINS=["*"]
